{
  "pathname": "chinese",
  "htmlBlock": "<!DOCTYPE html>\n<html lang=\"vi\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Học Tiếng Trung - Luyện Viết & Đối Chiếu</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700&family=Inter:wght@400;600&display=swap\" rel=\"stylesheet\">\n    <style>\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #f8fafc;\n        }\n        .hanzi-font {\n            font-family: 'Noto Sans SC', sans-serif;\n        }\n        #gameCanvas {\n            touch-action: none;\n            background-image: \n                linear-gradient(to right, #fee2e2 1px, transparent 1px),\n                linear-gradient(to bottom, #fee2e2 1px, transparent 1px),\n                linear-gradient(45deg, #fee2e2 0.5px, transparent 0.5px),\n                linear-gradient(-45deg, #fee2e2 0.5px, transparent 0.5px);\n            background-size: 100% 100%, 100% 100%, 100% 100%, 100% 100%;\n            background-position: center;\n            cursor: crosshair;\n        }\n        .canvas-container {\n            position: relative;\n            width: 100%;\n            max-width: 450px;\n            aspect-ratio: 1 / 1;\n        }\n        .grid-lines {\n            position: absolute;\n            top: 0; left: 0; width: 100%; height: 100%;\n            pointer-events: none; border: 2px solid #ef4444;\n        }\n        .grid-lines::before {\n            content: ''; position: absolute; top: 50%; left: 0; width: 100%; height: 1px; border-top: 1px dashed #fca5a5;\n        }\n        .grid-lines::after {\n            content: ''; position: absolute; left: 50%; top: 0; width: 1px; height: 100%; border-left: 1px dashed #fca5a5;\n        }\n        .diagonal-1, .diagonal-2 {\n            position: absolute; width: 141.4%; height: 1px; border-top: 1px dotted #fee2e2;\n        }\n        .diagonal-1 { top: 0; left: 0; transform: rotate(45deg); transform-origin: top left; }\n        .diagonal-2 { top: 0; right: 0; transform: rotate(-45deg); transform-origin: top right; }\n        \n        .loading-dots:after {\n            content: '.'; animation: dots 1.5s steps(5, end) infinite;\n        }\n        @keyframes dots {\n            0%, 20% { content: '.'; }\n            40% { content: '..'; }\n            60% { content: '...'; }\n            80%, 100% { content: ''; }\n        }\n        .feedback-pop { animation: popIn 0.3s ease-out; }\n        @keyframes popIn { 0% { transform: scale(0.9); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }\n        \n        .rotate-icon { transition: transform 0.5s ease; }\n        .rotate-icon:active { transform: rotate(360deg); }\n    </style>\n</head>\n<body class=\"min-h-screen flex flex-col\">\n\n    <header class=\"bg-white shadow-sm py-4 px-6 border-b border-gray-200\">\n        <div class=\"max-w-6xl mx-auto flex justify-between items-center\">\n            <h1 class=\"text-2xl font-bold text-red-600 flex items-center gap-2\">\n                <span class=\"text-3xl\">墨</span> Luyện Viết Tiếng Trung\n            </h1>\n            <div class=\"text-sm text-gray-400 font-medium italic\">Tự đối chiếu & Thống kê</div>\n        </div>\n    </header>\n\n    <main class=\"flex-grow container mx-auto px-4 py-8\">\n        <div class=\"max-w-4xl mx-auto\">\n            <div class=\"bg-white p-8 rounded-3xl shadow-sm border border-gray-100 relative overflow-hidden\">\n                \n                <!-- Feedback Overlay -->\n                <div id=\"feedbackOverlay\" class=\"hidden absolute inset-0 z-50 flex items-center justify-center bg-white/95 backdrop-blur-md\">\n                    <div class=\"text-center feedback-pop max-w-md w-full p-6\">\n                        <h2 class=\"text-xl font-bold mb-6 text-gray-800\">Hãy so sánh nét vẽ của bạn:</h2>\n                        \n                        <div class=\"flex justify-center gap-8 mb-8\">\n                            <div class=\"text-center\">\n                                <p class=\"text-xs text-gray-400 uppercase mb-2\">Bạn đã viết</p>\n                                <div id=\"userResultPreview\" class=\"w-32 h-32 border-2 border-gray-200 rounded-lg bg-white overflow-hidden\">\n                                    <img id=\"userDrawingImg\" src=\"\" class=\"w-full h-full object-contain\">\n                                </div>\n                            </div>\n                            <div class=\"text-center\">\n                                <p class=\"text-xs text-gray-400 uppercase mb-2\">Đáp án chuẩn</p>\n                                <div class=\"w-32 h-32 border-2 border-red-200 rounded-lg bg-red-50 flex items-center justify-center\">\n                                    <span id=\"correctCharPreview\" class=\"hanzi-font text-7xl text-red-600\">?</span>\n                                </div>\n                            </div>\n                        </div>\n\n                        <p class=\"text-gray-600 mb-6 italic\">Bạn thấy mình viết đúng không?</p>\n                        \n                        <div class=\"flex gap-4\">\n                            <button id=\"markWrongBtn\" class=\"flex-1 py-4 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-2xl font-bold transition\">Sai rồi</button>\n                            <button id=\"markCorrectBtn\" class=\"flex-1 py-4 bg-green-600 hover:bg-green-700 text-white rounded-2xl font-bold transition shadow-lg shadow-green-100\">Chính xác</button>\n                        </div>\n                    </div>\n                </div>\n\n                <div id=\"gameSetup\">\n                    <h2 class=\"text-2xl font-bold mb-6 text-gray-800 text-center\">Thiết lập Luyện tập</h2>\n                    \n                    <div id=\"sheetInputContainer\">\n                        <label class=\"block text-sm font-bold text-gray-700 mb-2 px-1\">Link Google Sheet CSV:</label>\n                        <input type=\"text\" id=\"sheetUrl\" class=\"w-full p-4 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-400 focus:outline-none mb-6\" placeholder=\"Nhập link CSV của bạn...\" value=\"https://docs.google.com/spreadsheets/d/e/2PACX-1vSH1u3gsoSKe2T8Cm_RtAqmk7SyE3PENI1mFz0vaU2wxZGYQv10Lus3QMfyXjgsunf-hYuxiZuoylPJ/pub?output=csv\">\n                    </div>\n\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4 mb-8 p-6 bg-gray-50 rounded-2xl border border-gray-100\">\n                        <div class=\"flex flex-col\">\n                            <label class=\"text-sm font-bold text-gray-700 mb-2\">Số lần lặp lại mỗi từ:</label>\n                            <input type=\"number\" id=\"repeatCount\" value=\"5\" min=\"1\" max=\"50\" class=\"p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-400 focus:outline-none\">\n                        </div>\n                        <div class=\"flex items-center justify-start md:justify-center pt-6\">\n                            <label class=\"relative inline-flex items-center cursor-pointer\">\n                                <input type=\"checkbox\" id=\"hideHanzi\" class=\"sr-only peer\" checked>\n                                <div class=\"w-11 h-6 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-red-600 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all\"></div>\n                                <span class=\"ml-3 text-sm font-medium text-gray-700\">Ẩn chữ Hán khi viết</span>\n                            </label>\n                        </div>\n                    </div>\n\n                    <button id=\"startGameBtn\" class=\"w-full py-4 bg-red-600 text-white font-bold rounded-xl hover:bg-red-700 transition shadow-lg flex justify-center items-center gap-2\">\n                        Bắt đầu Luyện tập\n                    </button>\n                    \n                    <div id=\"loadingOverlay\" class=\"hidden mt-4 text-center text-red-600 font-medium italic\">\n                        <span class=\"loading-dots\">Đang chuẩn bị dữ liệu</span>\n                    </div>\n                </div>\n\n                <!-- Game Active Screen -->\n                <div id=\"gameActive\" class=\"hidden flex flex-col items-center\">\n                    <div class=\"w-full flex justify-between items-center mb-4\">\n                        <button onclick=\"resetGame()\" class=\"text-gray-400 hover:text-gray-600 flex items-center gap-1 text-sm font-medium\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M10 19l-7-7m0 0l7-7m-7 7h18\" />\n                            </svg> Thoát\n                        </button>\n                        <div class=\"flex gap-4 text-sm font-bold\">\n                            <span class=\"text-green-600\">✓ <span id=\"liveCorrectCount\">0</span></span>\n                            <span class=\"text-red-500\">✗ <span id=\"liveWrongCount\">0</span></span>\n                        </div>\n                    </div>\n\n                    <div class=\"w-full bg-gray-100 h-3 rounded-full mb-6 overflow-hidden\">\n                        <div id=\"gameProgress\" class=\"bg-red-500 h-full transition-all duration-300\" style=\"width: 0%\"></div>\n                    </div>\n                    \n                    <div class=\"flex flex-col md:flex-row items-center gap-12 w-full justify-center\">\n                        <div class=\"text-center w-full md:w-1/3\">\n                            <h3 class=\"text-xs text-gray-400 uppercase tracking-widest mb-2 font-bold\">Hãy viết:</h3>\n                            <div id=\"targetChar\" class=\"hanzi-font text-8xl text-red-600 font-bold mb-2\">?</div>\n                            <div id=\"gameHints\" class=\"mb-4\">\n                                <p id=\"gamePinyin\" class=\"text-xl text-blue-600 font-semibold\"></p>\n                                <p id=\"gameMeaning\" class=\"text-sm text-gray-500 italic\"></p>\n                            </div>\n                            <p id=\"gameStats\" class=\"text-xs text-gray-400 font-medium\">Câu: 1 / 10</p>\n                        </div>\n                        <div class=\"flex flex-col items-center\">\n                            <div class=\"canvas-container shadow-2xl border-4 border-red-50 rounded-xl overflow-hidden bg-white\">\n                                <div class=\"grid-lines\"><div class=\"diagonal-1\"></div><div class=\"diagonal-2\"></div></div>\n                                <canvas id=\"gameCanvas\"></canvas>\n                            </div>\n                            <div class=\"flex gap-3 mt-4 w-full\">\n                                <button onclick=\"clearGameCanvas()\" class=\"flex-1 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl font-medium transition\">Xóa</button>\n                                <button id=\"checkBtn\" class=\"flex-[2] py-3 bg-red-600 hover:bg-red-700 text-white rounded-xl font-bold transition flex justify-center items-center gap-2\">\n                                    <span>Xong & Kiểm tra</span>\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Result Summary Screen -->\n                <div id=\"gameComplete\" class=\"hidden py-6\">\n                    <div class=\"text-center mb-8\">\n                        <div class=\"text-6xl mb-4\">🎉</div>\n                        <h2 class=\"text-3xl font-bold text-gray-800 mb-2\">Hoàn thành buổi tập!</h2>\n                        <p class=\"text-gray-500 italic\">Dưới đây là kết quả của bạn</p>\n                    </div>\n\n                    <div class=\"grid grid-cols-2 gap-4 mb-8\">\n                        <div class=\"bg-green-50 p-6 rounded-2xl border border-green-100 text-center\">\n                            <p class=\"text-green-600 font-bold text-sm uppercase mb-1\">Chính xác</p>\n                            <p id=\"finalCorrectCount\" class=\"text-4xl font-black text-green-700\">0</p>\n                        </div>\n                        <div class=\"bg-red-50 p-6 rounded-2xl border border-red-100 text-center\">\n                            <p class=\"text-red-600 font-bold text-sm uppercase mb-1\">Cần xem lại</p>\n                            <p id=\"finalWrongCount\" class=\"text-4xl font-black text-red-700\">0</p>\n                        </div>\n                    </div>\n\n                    <div id=\"wrongWordsSection\" class=\"hidden mb-8\">\n                        <h3 class=\"font-bold text-gray-700 mb-4 px-1 flex items-center gap-2\">\n                            <span class=\"text-red-500\">⚠</span> Danh sách các câu viết sai:\n                        </h3>\n                        <div id=\"wrongWordsList\" class=\"space-y-2 max-h-60 overflow-y-auto pr-2\">\n                            <!-- Words will be injected here -->\n                        </div>\n                    </div>\n\n                    <div class=\"flex flex-col gap-3\">\n                        <button onclick=\"startSession(true)\" class=\"w-full py-4 bg-red-600 text-white rounded-xl font-bold hover:bg-red-700 transition shadow-lg\">Luyện tập lại</button>\n                        <button onclick=\"resetGame()\" class=\"w-full py-4 bg-gray-100 text-gray-600 rounded-xl font-bold hover:bg-gray-200 transition\">Quay lại trang chính</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    <script>\n        let isDrawing = false, lastX = 0, lastY = 0;\n        let gCanvas, gCtx;\n        let gameQueue = [], currentIndex = 0, isHidingHanzi = true;\n        let currentRawWords = [];\n        \n        // Stats tracking\n        let correctCount = 0;\n        let wrongCount = 0;\n        let wrongWordsHistory = [];\n\n        function setupCanvas(targetCanvas, container) {\n            const size = container.clientWidth;\n            targetCanvas.width = size;\n            targetCanvas.height = size;\n            const ctx = targetCanvas.getContext('2d');\n            ctx.lineJoin = 'round'; ctx.lineCap = 'round'; \n            ctx.lineWidth = size / 35;\n            ctx.strokeStyle = '#1a1a1a';\n            return ctx;\n        }\n\n        function getPos(e, canvas) {\n            const rect = canvas.getBoundingClientRect();\n            const clientX = e.touches ? e.touches[0].clientX : e.clientX;\n            const clientY = e.touches ? e.touches[0].clientY : e.clientY;\n            return { x: clientX - rect.left, y: clientY - rect.top };\n        }\n\n        function bindCanvasEvents(canvas, ctx) {\n            const start = (e) => { isDrawing = true; const pos = getPos(e, canvas); [lastX, lastY] = [pos.x, pos.y]; };\n            const draw = (e) => { if (!isDrawing) return; const pos = getPos(e, canvas); ctx.beginPath(); ctx.moveTo(lastX, lastY); ctx.lineTo(pos.x, pos.y); ctx.stroke(); [lastX, lastY] = [pos.x, pos.y]; };\n            const stop = () => isDrawing = false;\n            canvas.addEventListener('mousedown', start); canvas.addEventListener('mousemove', draw); canvas.addEventListener('mouseup', stop);\n            canvas.addEventListener('touchstart', (e) => { e.preventDefault(); start(e); }, {passive: false});\n            canvas.addEventListener('touchmove', (e) => { e.preventDefault(); draw(e); }, {passive: false});\n            canvas.addEventListener('touchend', stop);\n        }\n\n        function parseCSV(str) {\n            const arr = []; let quote = false;\n            for (let row = col = c = 0; c < str.length; c++) {\n                let cc = str[c], nc = str[c+1];\n                arr[row] = arr[row] || []; arr[row][col] = arr[row][col] || \"\";\n                if (cc == '\"' && quote && nc == '\"') { arr[row][col] += cc; ++c; continue; }\n                if (cc == '\"') { quote = !quote; continue; }\n                if (cc == ',' && !quote) { ++col; continue; }\n                if (cc == '\\n' && !quote) { ++row; col = 0; continue; }\n                arr[row][col] += cc;\n            }\n            return arr;\n        }\n\n        async function parseCSVFromSheet(url) {\n            const cacheBuster = `&cb=${Date.now()}`;\n            const finalUrl = url.includes('?') ? `${url}${cacheBuster}` : `${url}?${cacheBuster}`;\n            const res = await fetch(finalUrl);\n            const text = await res.text();\n            const data = parseCSV(text);\n            return data.slice(1).filter(cols => cols[0]).map(cols => ({\n                char: cols[0].trim(), pinyin: (cols[1] || \"\").trim(), meaning: (cols[2] || \"\").trim()\n            }));\n        }\n\n        function createSmartQueue(words, repeats) {\n            let fullList = [];\n            words.forEach(w => {\n                for(let i=0; i<repeats; i++) fullList.push({...w});\n            });\n            let result = [];\n            let lastChar = null;\n            while (fullList.length > 0) {\n                let validChoices = fullList.filter(item => item.char !== lastChar);\n                if (validChoices.length === 0) validChoices = fullList;\n                const randomIndex = Math.floor(Math.random() * validChoices.length);\n                const chosenItem = validChoices[randomIndex];\n                const originalIndex = fullList.indexOf(chosenItem);\n                result.push(chosenItem);\n                lastChar = chosenItem.char;\n                fullList.splice(originalIndex, 1);\n            }\n            return result;\n        }\n\n        async function startSession(isRetry = false) {\n            const loading = document.getElementById('loadingOverlay');\n            const url = document.getElementById('sheetUrl').value.trim();\n            if (!url) return alert(\"Vui lòng nhập link Google Sheet.\");\n            \n            loading.classList.remove('hidden');\n            try {\n                if (!isRetry || currentRawWords.length === 0) {\n                    currentRawWords = await parseCSVFromSheet(url);\n                }\n                const repeats = parseInt(document.getElementById('repeatCount').value) || 5;\n                isHidingHanzi = document.getElementById('hideHanzi').checked;\n                \n                gameQueue = createSmartQueue(currentRawWords, repeats);\n                currentIndex = 0;\n                correctCount = 0;\n                wrongCount = 0;\n                wrongWordsHistory = [];\n                \n                document.getElementById('liveCorrectCount').innerText = '0';\n                document.getElementById('liveWrongCount').innerText = '0';\n                document.getElementById('gameSetup').classList.add('hidden');\n                document.getElementById('gameComplete').classList.add('hidden');\n                document.getElementById('gameActive').classList.remove('hidden');\n                \n                updateGameUI();\n                \n                setTimeout(() => { \n                    gCanvas = document.getElementById('gameCanvas');\n                    gCtx = setupCanvas(gCanvas, gCanvas.parentElement); \n                    bindCanvasEvents(gCanvas, gCtx); \n                }, 100);\n\n            } catch (e) { \n                alert(\"Lỗi khi tải dữ liệu. Hãy đảm bảo link đã được 'Xuất bản trên web' dưới dạng CSV.\"); \n            }\n            loading.classList.add('hidden');\n        }\n\n        document.getElementById('startGameBtn').onclick = () => startSession(false);\n\n        function updateGameUI() {\n            if (currentIndex >= gameQueue.length) {\n                showFinalResults();\n                return;\n            }\n            const item = gameQueue[currentIndex];\n            const target = document.getElementById('targetChar');\n            target.innerText = isHidingHanzi ? '?' : item.char;\n            target.className = isHidingHanzi ? \"hanzi-font text-8xl text-gray-200 font-bold mb-2\" : \"hanzi-font text-8xl text-red-600 font-bold mb-2\";\n            document.getElementById('gamePinyin').innerText = item.pinyin;\n            document.getElementById('gameMeaning').innerText = item.meaning;\n            document.getElementById('gameStats').innerText = `Câu: ${currentIndex + 1} / ${gameQueue.length}`;\n            document.getElementById('gameProgress').style.width = `${(currentIndex / gameQueue.length) * 100}%`;\n            clearGameCanvas();\n        }\n\n        function showFinalResults() {\n            document.getElementById('gameActive').classList.add('hidden');\n            document.getElementById('gameComplete').classList.remove('hidden');\n            \n            document.getElementById('finalCorrectCount').innerText = correctCount;\n            document.getElementById('finalWrongCount').innerText = wrongCount;\n            \n            const wrongSection = document.getElementById('wrongWordsSection');\n            const wrongList = document.getElementById('wrongWordsList');\n            \n            if (wrongWordsHistory.length > 0) {\n                wrongSection.classList.remove('hidden');\n                wrongList.innerHTML = '';\n                \n                // Group by word to avoid showing the same word too many times if failed multiple times\n                const uniqueWrongs = Array.from(new Set(wrongWordsHistory.map(w => w.char)))\n                    .map(char => wrongWordsHistory.find(w => w.char === char));\n\n                uniqueWrongs.forEach(item => {\n                    const div = document.createElement('div');\n                    div.className = \"flex items-center gap-4 bg-white p-3 rounded-xl border border-gray-100 shadow-sm\";\n                    div.innerHTML = `\n                        <div class=\"hanzi-font text-2xl text-red-600 font-bold w-10 text-center\">${item.char}</div>\n                        <div class=\"flex-grow\">\n                            <div class=\"text-sm font-bold text-gray-800\">${item.pinyin}</div>\n                            <div class=\"text-xs text-gray-500 italic\">${item.meaning}</div>\n                        </div>\n                    `;\n                    wrongList.appendChild(div);\n                });\n            } else {\n                wrongSection.classList.add('hidden');\n            }\n        }\n\n        document.getElementById('checkBtn').onclick = () => {\n            const item = gameQueue[currentIndex];\n            const dataUrl = gCanvas.toDataURL();\n            document.getElementById('userDrawingImg').src = dataUrl;\n            document.getElementById('correctCharPreview').innerText = item.char;\n            document.getElementById('feedbackOverlay').classList.remove('hidden');\n        };\n\n        document.getElementById('markCorrectBtn').onclick = () => {\n            correctCount++;\n            document.getElementById('liveCorrectCount').innerText = correctCount;\n            nextStep();\n        };\n\n        document.getElementById('markWrongBtn').onclick = () => {\n            wrongCount++;\n            document.getElementById('liveWrongCount').innerText = wrongCount;\n            wrongWordsHistory.push(gameQueue[currentIndex]);\n            nextStep();\n        };\n\n        function nextStep() {\n            document.getElementById('feedbackOverlay').classList.add('hidden');\n            currentIndex++;\n            updateGameUI();\n        }\n\n        function clearGameCanvas() { if(gCtx) gCtx.clearRect(0, 0, gCanvas.width, gCanvas.height); }\n\n        function resetGame() {\n            document.getElementById('gameComplete').classList.add('hidden');\n            document.getElementById('gameActive').classList.add('hidden');\n            document.getElementById('gameSetup').classList.remove('hidden');\n        }\n    </script>\n</body>\n</html>"
}