{
  "pathname": "colyseus",
  "htmlBlock": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Colyseus Cluster Visualizer</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@400;600;800&display=swap');\n        \n        :root {\n            --bg-color: #0f172a;\n            --node-bg: #1e293b;\n            --redis-bg: #450a0a;\n            --accent-indigo: #6366f1;\n            --accent-rose: #f43f5e;\n            --accent-emerald: #10b981;\n        }\n\n        body { \n            font-family: 'Inter', sans-serif; \n            background-color: var(--bg-color);\n            color: #f1f5f9;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n\n        .canvas-area {\n            background-image: radial-gradient(#334155 1px, transparent 1px);\n            background-size: 20px 20px;\n        }\n\n        /* Simplified Box Structures */\n        .box-container {\n            @apply border-2 rounded-lg p-4 bg-slate-800/50 backdrop-blur-sm relative transition-all duration-300;\n            min-width: 180px;\n            border-color: #334155;\n        }\n\n        .box-title {\n            @apply absolute -top-3 left-4 px-2 text-[10px] font-bold uppercase tracking-widest bg-slate-900 border border-slate-700 rounded;\n        }\n\n        .redis-box {\n            @apply border-rose-500/50 bg-rose-950/20 shadow-[0_0_20px_rgba(244,63,94,0.1)];\n        }\n\n        .node-box {\n            @apply border-indigo-500/30;\n        }\n\n        .node-box.active {\n            @apply border-indigo-500 shadow-[0_0_15px_rgba(99,102,241,0.2)];\n        }\n\n        .client-box {\n            @apply border-slate-600 bg-slate-900 flex flex-col items-center justify-center p-3 rounded-xl;\n            width: 80px;\n            height: 80px;\n        }\n\n        /* Data Packet */\n        .packet {\n            position: absolute;\n            width: 8px;\n            height: 8px;\n            border-radius: 50%;\n            z-index: 50;\n            pointer-events: none;\n            filter: blur(1px);\n        }\n\n        /* Buttons */\n        .nav-btn {\n            @apply px-4 py-2 rounded-md text-xs font-bold transition-all border border-transparent;\n        }\n        .nav-btn.active {\n            @apply bg-indigo-600 text-white border-indigo-400 shadow-lg;\n        }\n        .nav-btn:not(.active) {\n            @apply text-slate-400 hover:bg-slate-800;\n        }\n\n        .ctrl-btn {\n            @apply w-12 h-12 bg-slate-700 hover:bg-indigo-600 rounded-lg flex items-center justify-center font-bold text-white transition-colors border-b-4 border-slate-900 active:border-b-0 active:translate-y-1;\n        }\n\n        .room-tag {\n            @apply mt-2 py-1 px-2 rounded bg-emerald-500/10 border border-emerald-500/40 text-emerald-400 text-[9px] font-mono text-center;\n        }\n\n        #log-container::-webkit-scrollbar { width: 4px; }\n        #log-container::-webkit-scrollbar-thumb { @apply bg-slate-700 rounded; }\n    </style>\n</head>\n<body class=\"flex h-screen\">\n\n    <!-- Left Panel: Simulation -->\n    <div class=\"flex-1 flex flex-col relative\">\n        <!-- Toolbar -->\n        <div class=\"h-14 border-b border-slate-800 flex items-center justify-between px-6 bg-slate-900/80 z-20\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-8 h-8 bg-indigo-600 rounded flex items-center justify-center font-black\">C</div>\n                <span class=\"text-sm font-bold tracking-tight\">Colyseus HA Cluster</span>\n            </div>\n            <div class=\"flex gap-2\">\n                <button id=\"btn-SINGLE\" onclick=\"setMode('SINGLE')\" class=\"nav-btn active\">Single Node</button>\n                <button id=\"btn-CLUSTER\" onclick=\"setMode('CLUSTER')\" class=\"nav-btn\">Multi-Node Cluster</button>\n            </div>\n        </div>\n\n        <!-- Canvas -->\n        <div id=\"canvas\" class=\"flex-1 relative canvas-area flex flex-col items-center justify-around p-12\">\n            \n            <!-- Infrastructure Layer (Redis) -->\n            <div id=\"redis-layer\" class=\"opacity-0 translate-y-4 transition-all duration-500\">\n                <div id=\"redis-box\" class=\"box-container redis-box flex flex-col items-center gap-2\">\n                    <div class=\"box-title text-rose-400\">Infrastructure</div>\n                    <div class=\"flex items-center gap-2\">\n                        <div class=\"w-2 h-2 rounded-full bg-rose-500 animate-pulse\"></div>\n                        <span class=\"text-xs font-bold text-rose-100\">REDIS PUB/SUB</span>\n                    </div>\n                    <div class=\"text-[9px] text-rose-400/70 font-mono\">Presence & Relay Service</div>\n                </div>\n            </div>\n\n            <!-- Server Layer -->\n            <div class=\"flex gap-24 items-center justify-center w-full\">\n                <!-- Node 1 -->\n                <div id=\"node-1\" class=\"box-container node-box active\">\n                    <div class=\"box-title text-indigo-400\">Server Node 01</div>\n                    <div class=\"space-y-2\">\n                        <div class=\"flex items-center justify-between\">\n                            <span class=\"text-[10px] text-slate-400 font-mono\">Status</span>\n                            <span class=\"text-[10px] text-emerald-400 font-bold uppercase\">Online</span>\n                        </div>\n                        <div id=\"room-1\" class=\"room-tag\">\n                            Room_ID: Match_01<br>\n                            (State Authoritative)\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Node 2 -->\n                <div id=\"node-2\" class=\"box-container node-box opacity-20 scale-95 transition-all duration-500\">\n                    <div class=\"box-title text-slate-400\">Server Node 02</div>\n                    <div class=\"space-y-2\">\n                        <div class=\"flex items-center justify-between\">\n                            <span class=\"text-[10px] text-slate-400 font-mono\">Status</span>\n                            <span id=\"node-2-status\" class=\"text-[10px] text-slate-500 font-bold uppercase\">Offline</span>\n                        </div>\n                        <div class=\"room-tag border-slate-700 text-slate-500 bg-transparent\">\n                            Proxy Relay<br>\n                            (Remote Sync)\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Client Layer -->\n            <div class=\"flex gap-48\">\n                <div id=\"client-1\" class=\"flex flex-col items-center gap-2\">\n                    <div class=\"client-box border-indigo-500/50 shadow-lg shadow-indigo-500/10\">\n                        <span class=\"text-xl font-black text-indigo-400\">P1</span>\n                    </div>\n                    <span class=\"text-[10px] font-bold text-slate-500 uppercase\">WebSocket Client A</span>\n                </div>\n\n                <div id=\"client-2\" class=\"flex flex-col items-center gap-2\">\n                    <div class=\"client-box border-orange-500/50 shadow-lg shadow-orange-500/10\">\n                        <span class=\"text-xl font-black text-orange-400\">P2</span>\n                    </div>\n                    <span class=\"text-[10px] font-bold text-slate-500 uppercase\">WebSocket Client B</span>\n                </div>\n            </div>\n\n            <!-- Connection SVG -->\n            <svg class=\"absolute inset-0 w-full h-full pointer-events-none -z-10\" id=\"svg-layer\">\n                <path id=\"link-p1-n1\" d=\"\" stroke=\"#6366f1\" stroke-width=\"1.5\" fill=\"none\" stroke-dasharray=\"4 4\" />\n                <path id=\"link-p2-target\" d=\"\" stroke=\"#f97316\" stroke-width=\"1.5\" fill=\"none\" stroke-dasharray=\"4 4\" />\n                <path id=\"link-n1-redis\" d=\"\" stroke=\"#f43f5e\" stroke-width=\"1.5\" fill=\"none\" stroke-dasharray=\"4 4\" class=\"opacity-0 transition-opacity\" />\n                <path id=\"link-n2-redis\" d=\"\" stroke=\"#f43f5e\" stroke-width=\"1.5\" fill=\"none\" stroke-dasharray=\"4 4\" class=\"opacity-0 transition-opacity\" />\n            </svg>\n        </div>\n    </div>\n\n    <!-- Right Panel: Controls & Logs -->\n    <div class=\"w-80 border-l border-slate-800 bg-slate-900/50 flex flex-col p-6 gap-6\">\n        <!-- Viewports -->\n        <div class=\"space-y-4\">\n            <div class=\"bg-black/40 rounded-lg p-3 border border-slate-800\">\n                <div class=\"text-[9px] font-bold text-slate-500 uppercase mb-2\">P1 Viewport</div>\n                <div class=\"h-16 bg-slate-950 rounded relative overflow-hidden\">\n                    <div id=\"view1-p1\" class=\"absolute w-3 h-3 bg-indigo-500 rounded-sm transition-all duration-200\"></div>\n                    <div id=\"view1-p2\" class=\"absolute w-3 h-3 bg-orange-500/30 rounded-sm transition-all duration-200\"></div>\n                </div>\n            </div>\n            <div class=\"bg-black/40 rounded-lg p-3 border border-slate-800\">\n                <div class=\"text-[9px] font-bold text-slate-500 uppercase mb-2\">P2 Viewport</div>\n                <div class=\"h-16 bg-slate-950 rounded relative overflow-hidden\">\n                    <div id=\"view2-p1\" class=\"absolute w-3 h-3 bg-indigo-500/30 rounded-sm transition-all duration-200\"></div>\n                    <div id=\"view2-p2\" class=\"absolute w-3 h-3 bg-orange-500 rounded-sm transition-all duration-200\"></div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Terminal -->\n        <div class=\"flex-1 flex flex-col min-h-0 bg-black/60 rounded-lg border border-slate-800 p-3 font-mono text-[10px]\">\n            <div class=\"text-slate-500 mb-2 border-b border-slate-800 pb-1 flex justify-between\">\n                <span>SYSTEM_LOG</span>\n                <button onclick=\"clearLogs()\" class=\"hover:text-white\">CLEAR</button>\n            </div>\n            <div id=\"log-container\" class=\"flex-1 overflow-y-auto space-y-1 text-emerald-500/70\"></div>\n        </div>\n\n        <!-- Inputs -->\n        <div class=\"flex flex-col items-center gap-4 bg-slate-800/40 p-4 rounded-xl border border-slate-700\">\n            <span class=\"text-[10px] font-bold text-slate-500\">CONTROL P1 (AUTHORITY TEST)</span>\n            <div class=\"grid grid-cols-3 gap-2\">\n                <div></div><button onmousedown=\"handleAction('W')\" class=\"ctrl-btn\">W</button><div></div>\n                <button onmousedown=\"handleAction('A')\" class=\"ctrl-btn\">A</button>\n                <button onmousedown=\"handleAction('S')\" class=\"ctrl-btn\">S</button>\n                <button onmousedown=\"handleAction('D')\" class=\"ctrl-btn\">D</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let currentMode = 'SINGLE';\n        let isProcessing = false;\n        const state = { p1: { x: 20, y: 20 }, p2: { x: 140, y: 50 } };\n        const canvas = document.getElementById('canvas');\n\n        function setMode(mode) {\n            if(isProcessing) return;\n            currentMode = mode;\n            \n            // UI Toggle\n            document.getElementById('btn-SINGLE').classList.toggle('active', mode === 'SINGLE');\n            document.getElementById('btn-CLUSTER').classList.toggle('active', mode === 'CLUSTER');\n\n            const n2 = document.getElementById('node-2');\n            const redisLayer = document.getElementById('redis-layer');\n            const n1redis = document.getElementById('link-n1-redis');\n            const n2redis = document.getElementById('link-n2-redis');\n\n            if(mode === 'CLUSTER') {\n                n2.style.opacity = \"1\"; n2.style.transform = \"scale(1)\";\n                document.getElementById('node-2-status').innerText = \"Online\";\n                document.getElementById('node-2-status').className = \"text-[10px] text-emerald-400 font-bold uppercase\";\n                redisLayer.style.opacity = \"1\"; redisLayer.style.transform = \"translateY(0)\";\n                n1redis.classList.remove('opacity-0'); n2redis.classList.remove('opacity-0');\n                log('SYS', 'Cluster initialized. Redis connected for Pub/Sub.');\n            } else {\n                n2.style.opacity = \"0.2\"; n2.style.transform = \"scale(0.95)\";\n                document.getElementById('node-2-status').innerText = \"Offline\";\n                document.getElementById('node-2-status').className = \"text-[10px] text-slate-500 font-bold uppercase\";\n                redisLayer.style.opacity = \"0\"; redisLayer.style.transform = \"translateY(20px)\";\n                n1redis.classList.add('opacity-0'); n2redis.classList.add('opacity-0');\n                log('SYS', 'Switched to Single Node. RAM storage used.');\n            }\n            setTimeout(drawLinks, 300);\n        }\n\n        function log(tag, msg) {\n            const container = document.getElementById('log-container');\n            const div = document.createElement('div');\n            div.innerHTML = `<span class=\"text-slate-600\">${new Date().toLocaleTimeString().split(' ')[0]}</span> <span class=\"text-indigo-400\">[${tag}]</span> ${msg}`;\n            container.appendChild(div);\n            container.scrollTop = container.scrollHeight;\n        }\n\n        function clearLogs() { document.getElementById('log-container').innerHTML = ''; }\n\n        function getCenter(id) {\n            const el = document.getElementById(id);\n            const rect = el.getBoundingClientRect();\n            const canvasRect = canvas.getBoundingClientRect();\n            return { x: rect.left + rect.width/2 - canvasRect.left, y: rect.top + rect.height/2 - canvasRect.top };\n        }\n\n        function drawLinks() {\n            const p1 = getCenter('client-1'), p2 = getCenter('client-2');\n            const n1 = getCenter('node-1'), n2 = getCenter('node-2'), redis = getCenter('redis-box');\n\n            document.getElementById('link-p1-n1').setAttribute('d', `M ${p1.x} ${p1.y} L ${n1.x} ${n1.y}`);\n            \n            if(currentMode === 'SINGLE') {\n                document.getElementById('link-p2-target').setAttribute('d', `M ${p2.x} ${p2.y} L ${n1.x} ${n1.y}`);\n            } else {\n                document.getElementById('link-p2-target').setAttribute('d', `M ${p2.x} ${p2.y} L ${n2.x} ${n2.y}`);\n                document.getElementById('link-n1-redis').setAttribute('d', `M ${n1.x} ${n1.y} L ${redis.x} ${redis.y}`);\n                document.getElementById('link-n2-redis').setAttribute('d', `M ${n2.x} ${n2.y} L ${redis.x} ${redis.y}`);\n            }\n        }\n\n        async function animPacket(from, to, color) {\n            return new Promise(res => {\n                const s = getCenter(from), e = getCenter(to);\n                const p = document.createElement('div');\n                p.className = 'packet';\n                p.style.backgroundColor = color;\n                p.style.boxShadow = `0 0 10px ${color}`;\n                canvas.appendChild(p);\n                p.animate([\n                    { left: s.x+'px', top: s.y+'px', opacity: 1 },\n                    { left: e.x+'px', top: e.y+'px', opacity: 1 }\n                ], { duration: 400, easing: 'ease-out' }).onfinish = () => { p.remove(); res(); };\n            });\n        }\n\n        async function handleAction(key) {\n            if(isProcessing) return;\n            isProcessing = true;\n\n            const move = 10;\n            if(key==='W') state.p1.y-=move; if(key==='S') state.p1.y+=move;\n            if(key==='A') state.p1.x-=move; if(key==='D') state.p1.x+=move;\n\n            if(currentMode === 'SINGLE') {\n                log('WSS', 'P1 -> Node_01: Process Input');\n                await animPacket('client-1', 'node-1', '#6366f1');\n                log('SYNC', 'Broadcast: State Updated');\n                await Promise.all([\n                    animPacket('node-1', 'client-1', '#6366f1'),\n                    animPacket('node-1', 'client-2', '#f97316')\n                ]);\n            } else {\n                log('WSS', 'P1 -> Node_01: Authority update');\n                await animPacket('client-1', 'node-1', '#6366f1');\n                \n                log('REDIS', 'Node_01 -> Redis: Publish Patch');\n                await animPacket('node-1', 'redis-box', '#f43f5e');\n                \n                log('SUB', 'Redis -> Node_02: Remote Relay received');\n                await animPacket('redis-box', 'node-2', '#f43f5e');\n                \n                log('SYNC', 'Nodes broadcasting to local clients');\n                await Promise.all([\n                    animPacket('node-1', 'client-1', '#6366f1'),\n                    animPacket('node-2', 'client-2', '#f97316')\n                ]);\n            }\n\n            updateViewports();\n            isProcessing = false;\n        }\n\n        function updateViewports() {\n            const map = { p1: ['view1-p1', 'view2-p1'], p2: ['view1-p2', 'view2-p2'] };\n            for(let key in map) {\n                map[key].forEach(id => {\n                    const el = document.getElementById(id);\n                    el.style.left = (state[key].x / 200 * 100) + '%';\n                    el.style.top = (state[key].y / 100 * 100) + '%';\n                });\n            }\n        }\n\n        window.onload = () => {\n            setMode('SINGLE');\n            updateViewports();\n            window.addEventListener('resize', drawLinks);\n        };\n    </script>\n</body>\n</html>"
}